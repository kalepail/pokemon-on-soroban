{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "asteroid-arena",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-20",
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ARENA",
        "class_name": "Arena"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Arena"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
